{
  "name": "attune-terminal",
  "version": "1.1.0",
  "description": "Lightweight macOS terminal wrapper for running Claude Code",
  "main": "src/main.js",
  "scripts": {
    "build": "node scripts/build.js",
    "start": "npm run build && electron .",
    "dev": "npm run build && NODE_ENV=development electron .",
    "dist": "npm run build && electron-builder --mac --arm64",
    "postinstall": "npx @electron/rebuild -f -w node-pty"
  },
  "build": {
    "appId": "co.attune.terminal",
    "productName": "Attune Terminal",
    "mac": {
      "target": [
        "dmg",
        "dir"
      ],
      "icon": "assets/icon.icns",
      "identity": null,
      "category": "public.app-category.developer-tools"
    },
    "files": [
      "src/**/*",
      "dist/**/*",
      "scripts/**/*"
    ],
    "extraResources": [
      "assets/icon.icns"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "directories": {
      "output": "out"
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "node-notifier": "^10.0.1",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.24.0"
  }
}
